# Copy to the repo-root .env (gitignored). Only GEMINI_API_KEY is required to
# smoke-test the agent graph; ClickHouse Cloud is required for the data layer.
GEMINI_API_KEY=

# ClickHouse Cloud — Connect panel in the console (TLS on 8443)
CLICKHOUSE_HOST=
CLICKHOUSE_PORT=8443
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DB=denials

# Datadog LLM Obs (optional — agent runs without it, just no traces)
DD_API_KEY=
DD_SITE=datadoghq.com
DD_LLMOBS_ML_APP=contract-denial-agent

# Nimble (optional — monitor falls back to plain requests if unset)
NIMBLE_API_KEY=

# Controllable demo policy page
DEMO_POLICY_URL=http://localhost:8080/index.html
